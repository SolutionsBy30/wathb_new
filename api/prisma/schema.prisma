// Wathb API — Prisma schema, Phase 0-3 scope (foundations, the loop, intelligence, delivery).
// Packages/subscriptions/discount codes/payments/geography are later phases —
// see the root README for what's deliberately out of scope right now.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  admin
  supervisor
  student
}

enum SupervisorType {
  parent
  instructor
}

enum Track {
  scientific
  humanities
}

enum QuestionType {
  mcq_single
  mcq_multi
  numeric_entry
  true_false
}

enum QuestionStatus {
  draft
  in_review
  published
  retired
}

enum BundleType {
  standard
  passage
  placement
}

enum WathbStatus {
  pending
  opened
  completed
  expired
  partial
}

enum MagicLinkPurpose {
  wathb
  weekly_report
  supervisor_report
  renewal
  link_invite
}

enum SubjectType {
  student
  supervisor
}

enum AccuracyBand {
  low
  mid
  high
}

enum SpeedBand {
  slow
  on_pace
  fast
}

model User {
  id               String    @id @default(uuid())
  mobileE164       String?   @unique
  email            String?   @unique
  passwordHash     String?
  name             String
  role             Role
  locale           String    @default("ar")
  timezone         String    @default("Asia/Riyadh")
  status           String    @default("active")
  whatsappOptInAt  DateTime?
  // NOT-010 — STOP/إيقاف is honored instantly and permanently: set once,
  // never auto-cleared. Every outbound send path must check this first.
  whatsappOptedOutAt DateTime?
  // ADM-085 — suspension is reversible and logged (see AuditLog), unlike
  // the STOP opt-out above. status flips to "suspended"/"active"; every
  // auth entry point (OTP request/verify, magic-link exchange, admin
  // login) checks status, and suspending revokes all live magic links.
  suspendedAt      DateTime?
  suspendReason    String?
  createdAt        DateTime  @default(now())

  student    Student?
  supervisor Supervisor?

  notifications Notification[]
  waSession     WaSession?

  @@map("users")
}

model Student {
  userId           String    @id
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  track            Track?
  targetTestId     String?
  targetTest       Test?     @relation(fields: [targetTestId], references: [id])
  targetScore      Int?
  testDate         DateTime?
  skipDays         Int[]     @default([5]) // 0=Sunday..6=Saturday; default skips Friday (spec §6.2, KSA weekend)
  notifSlotStartHour Int     @default(18)
  notifSlotEndHour   Int     @default(20)
  currentStreak    Int       @default(0)
  lastCompletedOn  DateTime?
  placementDoneAt  DateTime?
  // Optional and skippable per spec §4.8 (PDPL: not strictly necessary to
  // deliver daily practice, so collection must stay opt-in).
  schoolId         String?
  school           School?   @relation(fields: [schoolId], references: [id])

  wathbs             Wathb[]
  answers             Answer[]
  labelStats          StudentLabelStat[]
  supervisorLinks     StudentSupervisor[]
  subscriptions       Subscription[]
  problemReports      ProblemReport[]

  @@map("students")
}

// §3.4 — Region > City > School. Regions/cities are seeded and admin-extensible;
// schools come from an admin-managed registry or a student's self-declared
// suggestion (status=pending_review, never inserted directly — §3.4's "valve
// that keeps the registry clean").
model Region {
  id     String @id @default(uuid())
  nameAr String
  nameEn String
  cities City[]

  @@map("regions")
}

model City {
  id       String   @id @default(uuid())
  regionId String
  region   Region   @relation(fields: [regionId], references: [id], onDelete: Cascade)
  nameAr   String
  nameEn   String
  schools  School[]

  @@map("cities")
}

enum SchoolStatus {
  approved
  pending_review
}

model School {
  id                    String       @id @default(uuid())
  cityId                String
  city                  City         @relation(fields: [cityId], references: [id], onDelete: Cascade)
  nameAr                String
  nameEn                String?
  status                SchoolStatus @default(approved)
  suggestedByStudentId  String?
  createdAt             DateTime     @default(now())

  students Student[]

  @@map("schools")
}

model Supervisor {
  userId              String         @id
  user                User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  type                SupervisorType
  // §5.3 — supervisor can set day/time for the weekly report and mute it.
  weeklyReportDay     Int            @default(4) // 0=Sunday..6=Saturday; default Thursday
  weeklyReportHour    Int            @default(20)
  weeklyReportMuted   Boolean        @default(false)

  studentLinks StudentSupervisor[]

  @@map("supervisors")
}

model StudentSupervisor {
  id           String     @id @default(uuid())
  studentId    String
  student      Student    @relation(fields: [studentId], references: [userId], onDelete: Cascade)
  supervisorId String
  supervisor   Supervisor @relation(fields: [supervisorId], references: [userId], onDelete: Cascade)
  acceptedAt   DateTime?
  revokedAt    DateTime?

  @@unique([studentId, supervisorId])
  @@map("student_supervisors")
}

model Test {
  id       String    @id @default(uuid())
  nameAr   String
  nameEn   String
  isActive Boolean   @default(true)
  sections Section[]
  students Student[]

  @@map("tests")
}

model Section {
  id     String @id @default(uuid())
  testId String
  test   Test   @relation(fields: [testId], references: [id], onDelete: Cascade)
  nameAr String
  nameEn String
  weight Float  @default(1)
  sort   Int    @default(0)
  areas  Area[]

  @@map("sections")
}

model Area {
  id               String   @id @default(uuid())
  sectionId        String
  section          Section  @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  nameAr           String
  nameEn           String
  appliesToTracks  Track[]
  sort             Int      @default(0)
  labels           Label[]

  @@map("areas")
}

model Label {
  id                String     @id @default(uuid())
  areaId            String
  area              Area       @relation(fields: [areaId], references: [id], onDelete: Cascade)
  nameAr            String
  nameEn            String
  defaultTimeLimitS Int        @default(45)
  sort              Int        @default(0)
  isRetired         Boolean    @default(false)

  passages          Passage[]
  questions         Question[]
  labelStats        StudentLabelStat[]
  adviceRules       AdviceRule[]

  @@map("labels")
}

model Passage {
  id        String     @id @default(uuid())
  labelId   String
  label     Label      @relation(fields: [labelId], references: [id])
  body      String
  status    QuestionStatus @default(draft)
  questions Question[]

  @@map("passages")
}

model Question {
  id                String         @id @default(uuid())
  labelId           String
  label             Label          @relation(fields: [labelId], references: [id])
  passageId         String?
  passage           Passage?       @relation(fields: [passageId], references: [id])
  type              QuestionType   @default(mcq_single)
  difficulty        Int            @default(3)
  timeLimitS        Int?
  status            QuestionStatus @default(draft)
  source            String?
  stemHash          String
  currentVersionId  String?
  createdBy         String?
  createdAt         DateTime       @default(now())

  versions          QuestionVersion[] @relation("QuestionToVersions")
  wathbQuestions    WathbQuestion[]
  answers           Answer[]
  problemReports    ProblemReport[]

  @@index([labelId, status])
  @@index([stemHash])
  @@map("questions")
}

model QuestionVersion {
  id            String   @id @default(uuid())
  questionId    String
  question      Question @relation("QuestionToVersions", fields: [questionId], references: [id], onDelete: Cascade)
  version       Int
  stem          String
  stemImageUrl  String?
  options       Json
  correctKey    String
  explanation   String
  createdAt     DateTime @default(now())
  createdBy     String?

  wathbQuestions WathbQuestion[]
  answers        Answer[]
  stats          QuestionStats?

  @@unique([questionId, version])
  @@map("question_versions")
}

// §4.5.2 / §6 "solution performance" — is this question any good? Recomputed
// via an admin-triggered refresh (POST /api/admin/questions/refresh-stats),
// same manual-trigger pattern as plan_day/send_notification — no real cron
// in this sandbox. p_value/discrimination are null until enough volume
// exists (MIN_SAMPLE_FOR_REPORTING), same statistical-honesty discipline as
// student-facing reports.
model QuestionStats {
  questionVersionId String          @id
  questionVersion   QuestionVersion @relation(fields: [questionVersionId], references: [id], onDelete: Cascade)
  nServed           Int             @default(0)
  nCorrect          Int             @default(0)
  pValue            Float?
  discrimination    Float?
  meanTimeMs        Int             @default(0)
  timeoutRate       Float           @default(0)
  distractorDist    Json?
  // STU-012 — explanation 👍/👎 counts, surfaced on the admin solution-
  // performance screen alongside p-value/discrimination.
  explanationUpvotes   Int          @default(0)
  explanationDownvotes Int          @default(0)
  updatedAt         DateTime        @updatedAt

  @@map("question_stats")
}

model Wathb {
  id            String      @id @default(uuid())
  studentId     String
  student       Student     @relation(fields: [studentId], references: [userId], onDelete: Cascade)
  scheduledFor  DateTime    @db.Date
  bundleType    BundleType  @default(standard)
  status        WathbStatus @default(pending)
  openedAt      DateTime?
  completedAt   DateTime?
  magicLinkId   String?

  questions WathbQuestion[]
  answers   Answer[]

  @@unique([studentId, scheduledFor])
  @@map("wathbs")
}

model WathbQuestion {
  id                String          @id @default(uuid())
  wathbId           String
  wathb             Wathb           @relation(fields: [wathbId], references: [id], onDelete: Cascade)
  questionId        String
  question          Question        @relation(fields: [questionId], references: [id])
  questionVersionId String
  questionVersion   QuestionVersion @relation(fields: [questionVersionId], references: [id])
  position          Int
  servedAt          DateTime?

  @@unique([wathbId, position])
  @@map("wathb_questions")
}

model Answer {
  id                String          @id @default(uuid())
  wathbId           String
  wathb             Wathb           @relation(fields: [wathbId], references: [id], onDelete: Cascade)
  studentId         String
  student           Student         @relation(fields: [studentId], references: [userId], onDelete: Cascade)
  questionId        String
  question          Question        @relation(fields: [questionId], references: [id])
  questionVersionId String
  questionVersion   QuestionVersion @relation(fields: [questionVersionId], references: [id])
  labelId           String
  selectedKey       String?
  isCorrect         Boolean
  timeTakenMs       Int
  timedOut          Boolean         @default(false)
  isReview          Boolean         @default(false)
  answeredAt        DateTime        @default(now())
  // STU-012 — one-tap 👍/👎 on the explanation shown for this served answer.
  explanationRating ExplanationRating?

  problemReports    ProblemReport[]

  @@unique([wathbId, questionId])
  @@map("answers")
}

enum ExplanationRating {
  up
  down
}

// STU-012 — "report a problem" routes the flag, with the student's answer
// attached, to an admin inbox. A dedicated model (not AuditLog) because
// this needs its own open/resolved workflow state, not just an append-only
// event record.
model ProblemReport {
  id         String              @id @default(uuid())
  studentId  String
  student    Student             @relation(fields: [studentId], references: [userId], onDelete: Cascade)
  questionId String
  question   Question            @relation(fields: [questionId], references: [id], onDelete: Cascade)
  answerId   String?
  answer     Answer?             @relation(fields: [answerId], references: [id], onDelete: SetNull)
  note       String?
  status     ProblemReportStatus @default(open)
  createdAt  DateTime            @default(now())
  resolvedAt DateTime?
  resolvedBy String?

  @@index([status])
  @@map("problem_reports")
}

enum ProblemReportStatus {
  open
  resolved
}

model MagicLink {
  id            String            @id @default(uuid())
  tokenHash     String            @unique
  subjectId     String
  subjectType   SubjectType
  purpose       MagicLinkPurpose
  targetId      String?
  expiresAt     DateTime
  maxUses       Int               @default(1)
  uses          Int               @default(0)
  firstUsedAt   DateTime?
  lastUsedAt    DateTime?
  revokedAt     DateTime?
  createdAt     DateTime          @default(now())

  accessLog MagicLinkAccess[]

  @@map("magic_links")
}

model MagicLinkAccess {
  id          String    @id @default(uuid())
  magicLinkId String
  magicLink   MagicLink @relation(fields: [magicLinkId], references: [id], onDelete: Cascade)
  ip          String?
  userAgent   String?
  accessedAt  DateTime  @default(now())

  @@map("magic_link_access")
}

// Materialised on every answer write — the selection engine reads this, never `answers` directly.
model StudentLabelStat {
  studentId       String
  student         Student  @relation(fields: [studentId], references: [userId], onDelete: Cascade)
  labelId         String
  label           Label    @relation(fields: [labelId], references: [id], onDelete: Cascade)
  nAnswered       Int      @default(0)
  nCorrect        Int      @default(0)
  meanTimeMs      Int      @default(0)
  difficultyLevel Int      @default(3)
  lastServedAt    DateTime?

  @@id([studentId, labelId])
  @@map("student_label_stats")
}

// §6.5 — hand-written coaching strings, admin-editable data, not generated text.
model AdviceRule {
  id           String       @id @default(uuid())
  labelId      String
  label        Label        @relation(fields: [labelId], references: [id], onDelete: Cascade)
  accuracyBand AccuracyBand
  speedBand    SpeedBand
  textAr       String
  textEn       String

  @@unique([labelId, accuracyBand, speedBand])
  @@map("advice_rules")
}

// §7 — Notification & Magic Link Engine.

enum NotificationKind {
  daily_wathb
  nudge
  weekly_report_student
  weekly_report_supervisor
  streak_milestone
  subscription_expiring
  payment_failed
  supervisor_invite
  suspension
}

// "console" stands in for whatsapp_template/whatsapp_freeform when no WABA
// credentials are configured — see NotificationChannel in src/notifications.
enum NotifChannel {
  whatsapp_template
  whatsapp_freeform
  console
}

enum NotificationCategory {
  utility
  marketing
}

enum NotificationStatus {
  scheduled
  sent
  delivered
  read
  failed
  // NOT-009 — a neutral outcome (suspended user, already-completed Wathb)
  // is not a delivery failure and shouldn't read as one in the log.
  skipped
}

model Notification {
  id           String               @id @default(uuid())
  userId       String
  user         User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind         NotificationKind
  channel      NotifChannel
  templateName String?
  category     NotificationCategory
  waMessageId  String?
  scheduledFor DateTime             @db.Date
  sentAt       DateTime?
  deliveredAt  DateTime?
  readAt       DateTime?
  repliedAt    DateTime?
  wasBillable  Boolean              @default(false)
  costEstimate Float?
  status       NotificationStatus   @default(scheduled)
  error        String?
  createdAt    DateTime             @default(now())
  // NOT-009 — retry/fallback ladder for undelivered messages.
  retryCount   Int                  @default(0)
  nextRetryAt  DateTime?

  // Idempotency key (spec §7.3) — a duplicate daily message is a trust-destroying bug.
  @@unique([userId, kind, scheduledFor])
  @@index([status, nextRetryAt])
  @@map("notifications")
}

// One row per user — tracks Meta's 24h customer-service window (spec §7.2).
model WaSession {
  userId          String    @id
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  windowOpenedAt  DateTime?
  windowExpiresAt DateTime?
  lastInboundAt   DateTime?

  @@map("wa_sessions")
}

// Mobile + OTP login (spec §9.3 POST /api/auth/otp/request|verify), also the
// mechanism for step-up auth on sensitive actions later. Code is hashed at
// rest exactly like magic-link tokens — never stored in the clear.
model OtpCode {
  id          String      @id @default(uuid())
  mobileE164  String
  subjectType SubjectType
  codeHash    String
  expiresAt   DateTime
  attempts    Int         @default(0)
  consumedAt  DateTime?
  createdAt   DateTime    @default(now())

  @@index([mobileE164, subjectType])
  @@map("otp_codes")
}

// §4.5 / §9.2 — Packages & Pricing, §4.5's checkout + subscription lifecycle.
// Discount codes and ZATCA e-invoicing are explicitly out of scope for this
// pass — see the root README.

enum PackageVisibility {
  public
  link_only
}

enum ReportVisibility {
  full
  partial
}

// §3.13 FRE-007 — every free-tier limit is a package feature flag, enforced
// server-side at the API layer, never a code-level "is this the free
// package" special case. A paid package simply carries the unrestricted
// defaults below.
model Package {
  id              String            @id @default(uuid())
  nameAr          String
  nameEn          String
  testIds         String[]
  durationMonths  Int
  priceHalalas    Int // VAT-inclusive, 15% KSA — spec §4.5
  questionsPerDay Int               @default(5)
  isActive        Boolean           @default(true)
  visibility      PackageVisibility @default(public)
  dailyNotificationEnabled  Boolean           @default(true) // FRE-002
  reportVisibility          ReportVisibility  @default(full) // FRE-004
  weeklyReportEnabled       Boolean           @default(true) // FRE-005
  supervisorLinkingAllowed  Boolean           @default(true) // FRE-006
  createdAt       DateTime          @default(now())

  subscriptions Subscription[]

  @@map("packages")
}

enum SubscriptionStatus {
  pending
  active
  expired
  cancelled
  refunded
}

model Subscription {
  id                  String             @id @default(uuid())
  studentId           String
  student             Student            @relation(fields: [studentId], references: [userId], onDelete: Cascade)
  packageId           String
  package             Package            @relation(fields: [packageId], references: [id])
  // Snapshot at purchase time — spec §4.5: "changes [to package price] never
  // touch active subs."
  priceSnapshotHalalas Int
  startsAt            DateTime?
  endsAt               DateTime?
  status               SubscriptionStatus @default(pending)
  paymentRef           String?
  createdAt            DateTime           @default(now())

  @@map("subscriptions")
}

// ADM-085 — full audit trail of admin actions: manual/wire-transfer
// activations, suspensions, and any use of the OTP fallback (ONB-014).
// actorLabel is denormalized (name/email at the time of the action) so the
// log stays readable even if the actor account is later changed or removed.
model AuditLog {
  id         String   @id @default(uuid())
  actorId    String?
  actorLabel String
  action     String
  entityType String
  entityId   String
  before     Json?
  after      Json?
  note       String?
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}
