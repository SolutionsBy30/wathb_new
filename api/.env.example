DATABASE_URL="postgresql://wathb:wathb@localhost:5432/wathb"
JWT_SECRET="dev-secret-change-me"
PORT=4000
ALLOW_DEV_LOGIN=true

# Phase 3 — WhatsApp (Meta Business Messaging Cloud API). Leave unset to use
# the safe ConsoleChannel fallback (logs instead of sending) for local dev.
# WHATSAPP_ACCESS_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_WEBHOOK_VERIFY_TOKEN=
# WHATSAPP_APP_SECRET=
# WHATSAPP_TEMPLATE_DAILY_WATHB=daily_wathb_reminder
# WHATSAPP_TEMPLATE_OTP=wathb_otp_login
# WHATSAPP_TEMPLATE_WEEKLY_STUDENT=weekly_report_student
# WHATSAPP_TEMPLATE_WEEKLY_SUPERVISOR=weekly_report_supervisor
# NFR-005a — with NODE_ENV=production, the API refuses to boot unless
# WhatsApp is configured above, since the fixed fallback OTP code would
# otherwise be reachable for every login. Set this to override deliberately.
# ALLOW_OTP_FALLBACK_IN_PRODUCTION=true
STUDENT_APP_URL="http://localhost:5173/wathb"
SUPERVISOR_APP_URL="http://localhost:5175/supervisor"
API_PUBLIC_URL="http://localhost:4000/api"

# Phase 4 — Payments (Paymob no-code Intention API + hosted checkout). Leave
# unset to use the safe ConsolePaymentProvider fallback (checkout instantly
# "succeeds" via a dev-only endpoint) for local dev.
# PAYMOB_SECRET_KEY=
# PAYMOB_PUBLIC_KEY=
# PAYMOB_INTEGRATION_ID=
# PAYMOB_HMAC_SECRET=
